rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isValidQuestion(data) {
      return data.keys().hasAll(['grade', 'subject', 'q', 'ans']) &&
             data.grade is string && data.grade in ['2', '6'] &&
             data.subject is string && data.subject in ['math', 'vietnamese', 'english'] &&
             data.q is string && data.q.size() > 0 && data.q.size() < 1000 &&
             data.ans is string && data.ans.size() > 0 && data.ans.size() < 500;
    }
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'playerName', 'grade', 'subject', 'score', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.playerName is string && data.playerName.size() > 0 && data.playerName.size() < 100 &&
             data.grade is string && data.grade in ['2', '6'] &&
             data.subject is string && data.subject in ['math', 'vietnamese', 'english'] &&
             data.score is int && data.score >= 0 &&
             data.timestamp is string;
    }

    // Questions Collection
    match /questions/{questionId} {
      // Allow anyone to read questions
      allow read: if true;
      // Only authenticated users can create questions (e.g., when the app generates and saves them)
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data);
      // No updates or deletes for now
      allow update, delete: if false;
    }

    // Scores Collection
    match /scores/{scoreId} {
      // Allow users to read their own scores
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow authenticated users to create their own scores
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      // No updates or deletes for now
      allow update, delete: if false;
    }
  }
}
